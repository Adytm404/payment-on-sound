generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt        @id @default(autoincrement())
  name         String        @db.VarChar(100)
  email        String        @unique @db.VarChar(191)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  role         UserRole      @default(merchant)
  isActive     Boolean       @default(true) @map("is_active")
  adminNote    String?       @map("admin_note") @db.Text
  planId       BigInt?       @map("plan_id")
  planExpiresAt DateTime?    @map("plan_expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  settings     UserSettings?
  transactions Transaction[]
  planOrders   PlanOrder[]
  withdrawalRequests WithdrawalRequest[]
  passwordResetTokens PasswordResetToken[]
  plan         Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([planId], map: "idx_users_plan_id")
  @@map("users")
}

model Plan {
  id                      BigInt   @id @default(autoincrement())
  name                    String   @db.VarChar(100)
  slug                    String   @unique @db.VarChar(50)
  description             String   @db.Text
  price                   Int      @default(0)
  billingPeriodDays       Int?     @map("billing_period_days")
  monthlyTransactionLimit Int?     @map("monthly_transaction_limit")
  maxTransactionAmount    Int?     @map("max_transaction_amount")
  reportRetentionDays     Int?     @map("report_retention_days")
  canUseRealtime          Boolean  @default(false) @map("can_use_realtime")
  canExportReports        Boolean  @default(false) @map("can_export_reports")
  canUseTts               Boolean  @default(true) @map("can_use_tts")
  canUsePublicPaymentPage Boolean  @default(true) @map("can_use_public_payment_page")
  canSeeAdminFee          Boolean  @default(true) @map("can_see_admin_fee")
  isActive                Boolean  @default(true) @map("is_active")
  sortOrder               Int      @default(0) @map("sort_order")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  users                   User[]
  planOrders              PlanOrder[]

  @@map("plans")
}

model PlatformSettings {
  id                 BigInt   @id @default(autoincrement())
  duitkuMerchantCode String   @default("") @map("duitku_merchant_code") @db.VarChar(100)
  duitkuApiKey       String   @default("") @map("duitku_api_key") @db.Text
  duitkuSandbox      Boolean  @default(true) @map("duitku_sandbox")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model PromoCode {
  id             BigInt      @id @default(autoincrement())
  code           String      @unique @db.VarChar(50)
  name           String      @db.VarChar(100)
  type           PromoType
  discountPercent Int?       @map("discount_percent")
  discountAmount Int?        @map("discount_amount")
  trialDays      Int?        @map("trial_days")
  maxRedemptions Int?        @map("max_redemptions")
  usedCount      Int         @default(0) @map("used_count")
  startsAt       DateTime?   @map("starts_at")
  expiresAt      DateTime?   @map("expires_at")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  planOrders     PlanOrder[]

  @@map("promo_codes")
}

model PlanOrder {
  id                BigInt          @id @default(autoincrement())
  userId            BigInt          @map("user_id")
  planId            BigInt          @map("plan_id")
  promoCodeId       BigInt?         @map("promo_code_id")
  orderId           String          @unique @map("order_id") @db.VarChar(64)
  provider          String          @default("duitku_pop") @db.VarChar(50)
  providerReference String?         @map("provider_reference") @db.VarChar(255)
  amount            Int
  discountAmount    Int             @default(0) @map("discount_amount")
  finalAmount       Int             @map("final_amount")
  status            PlanOrderStatus @default(pending)
  paymentUrl        String?         @map("payment_url") @db.Text
  paidAt            DateTime?       @map("paid_at")
  expiresAt         DateTime?       @map("expires_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  promoCode         PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([userId, status], map: "idx_plan_orders_user_status")
  @@index([providerReference], map: "idx_plan_orders_provider_reference")
  @@map("plan_orders")
}

enum PromoType {
  free_trial
  percentage_discount
  fixed_discount
}

enum PlanOrderStatus {
  pending
  paid
  failed
  expired
  cancelled
}

enum UserRole {
  admin
  merchant
}

model UserSettings {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @unique @map("user_id")
  merchantName   String   @default("Merchant") @map("merchant_name") @db.VarChar(100)
  merchantStatus MerchantStatus @default(draft) @map("merchant_status")
  legalName      String?  @map("legal_name") @db.VarChar(100)
  ktpNumber      String?  @map("ktp_number") @db.VarChar(32)
  withdrawBankCode String? @map("withdraw_bank_code") @db.VarChar(50)
  withdrawBankName String? @map("withdraw_bank_name") @db.VarChar(100)
  withdrawAccountNumber String? @map("withdraw_account_number") @db.VarChar(64)
  withdrawAccountName String? @map("withdraw_account_name") @db.VarChar(100)
  merchantNameValid Boolean @default(false) @map("merchant_name_valid")
  legalNameValid Boolean @default(false) @map("legal_name_valid")
  ktpNumberValid Boolean @default(false) @map("ktp_number_valid")
  withdrawBankValid Boolean @default(false) @map("withdraw_bank_valid")
  withdrawAccountNumberValid Boolean @default(false) @map("withdraw_account_number_valid")
  withdrawAccountNameValid Boolean @default(false) @map("withdraw_account_name_valid")
  merchantNameNote String? @map("merchant_name_note") @db.Text
  legalNameNote String? @map("legal_name_note") @db.Text
  ktpNumberNote String? @map("ktp_number_note") @db.Text
  withdrawBankNote String? @map("withdraw_bank_note") @db.Text
  withdrawAccountNumberNote String? @map("withdraw_account_number_note") @db.Text
  withdrawAccountNameNote String? @map("withdraw_account_name_note") @db.Text
  verificationNote String? @map("verification_note") @db.Text
  submittedAt DateTime? @map("submitted_at")
  verifiedAt DateTime? @map("verified_at")
  verifiedByAdminId BigInt? @map("verified_by_admin_id")
  pakasirProject String   @default("") @map("pakasir_project") @db.VarChar(100)
  pakasirApiKey  String   @map("pakasir_api_key") @db.Text
  sandbox        Boolean  @default(true)
  ttsEnabled     Boolean  @default(true) @map("tts_enabled")
  ttsVoiceURI    String   @default("") @map("tts_voice_uri") @db.VarChar(255)
  ttsRate        Decimal  @default(1.00) @map("tts_rate") @db.Decimal(3, 2)
  ttsPitch       Decimal  @default(1.00) @map("tts_pitch") @db.Decimal(3, 2)
  ttsVolume      Decimal  @default(1.00) @map("tts_volume") @db.Decimal(3, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum MerchantStatus {
  draft
  pending_review
  needs_revision
  verified
  rejected
}

model Transaction {
  id            BigInt            @id @default(autoincrement())
  userId        BigInt            @map("user_id")
  orderId       String            @map("order_id") @db.VarChar(64)
  description   String?           @db.VarChar(255)
  amount        Int
  fee           Int               @default(0)
  totalPayment  Int               @map("total_payment")
  paymentNumber String            @map("payment_number") @db.Text
  paymentMethod String            @default("qris") @map("payment_method") @db.VarChar(50)
  status        TransactionStatus @default(pending)
  createdAt     DateTime          @default(now()) @map("created_at")
  expiredAt     DateTime          @map("expired_at")
  completedAt   DateTime?         @map("completed_at")
  settledAt     DateTime?         @map("settled_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orderId], map: "transactions_user_order_id_key")
  @@index([userId, orderId], map: "idx_user_order_id")
  @@index([userId, status, createdAt], map: "idx_user_status_created")
  @@index([userId, status, settledAt], map: "idx_user_status_settled_at")
  @@index([userId, createdAt], map: "idx_user_created")
  @@index([userId, amount], map: "idx_user_amount")
  @@index([userId, totalPayment], map: "idx_user_total_payment")
  @@map("transactions")
}

enum TransactionStatus {
  pending
  completed
  cancelled
  expired
  failed
}

model WithdrawalRequest {
  id            BigInt           @id @default(autoincrement())
  userId        BigInt           @map("user_id")
  requestId     String           @unique @map("request_id") @db.VarChar(64)
  amount        Int
  status        WithdrawalStatus @default(pending)
  bankCode      String           @map("bank_code") @db.VarChar(50)
  bankName      String           @map("bank_name") @db.VarChar(100)
  accountNumber String           @map("account_number") @db.VarChar(64)
  accountName   String           @map("account_name") @db.VarChar(100)
  userNote      String?          @map("user_note") @db.Text
  adminNote     String?          @map("admin_note") @db.Text
  approvedAt    DateTime?        @map("approved_at")
  processedAt   DateTime?        @map("processed_at")
  paidAt        DateTime?        @map("paid_at")
  rejectedAt    DateTime?        @map("rejected_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status], map: "idx_withdrawals_user_status")
  @@index([status, createdAt], map: "idx_withdrawals_status_created")
  @@map("withdrawal_requests")
}

enum WithdrawalStatus {
  pending
  approved
  processing
  paid
  rejected
  cancelled
}

model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token], map: "idx_password_reset_token")
  @@map("password_reset_tokens")
}
